#!/usr/bin/env bash
# rezops-relink — re-create skill symlinks based on skill_prefix config
#
# Usage:
#   rezops-relink
#
# Env overrides (for testing):
#   REZOPS_STATE_DIR   — override ~/.rezops state directory
#   REZOPS_INSTALL_DIR — override rezops install directory
#   REZOPS_SKILLS_DIR  — override target skills directory
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REZOPS_CONFIG="${SCRIPT_DIR}/rezops-config"

# Detect install dir
INSTALL_DIR="${REZOPS_INSTALL_DIR:-}"
if [ -z "$INSTALL_DIR" ]; then
  if [ -d "$HOME/.claude/skills/rezops" ]; then
    INSTALL_DIR="$HOME/.claude/skills/rezops"
  elif [ -d "${SCRIPT_DIR}/.." ] && [ -f "${SCRIPT_DIR}/../setup" ]; then
    INSTALL_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
  fi
fi

if [ -z "$INSTALL_DIR" ] || [ ! -d "$INSTALL_DIR" ]; then
  echo "Error: rezops install directory not found." >&2
  echo "Run: cd ~/.claude/skills/rezops && ./setup" >&2
  exit 1
fi

# Detect target skills dir
SKILLS_DIR="${REZOPS_SKILLS_DIR:-$(dirname "$INSTALL_DIR")}"
[ -d "$SKILLS_DIR" ] || mkdir -p "$SKILLS_DIR"

# Read prefix setting
PREFIX=$("$REZOPS_CONFIG" get skill_prefix 2>/dev/null || echo "false")

# Helper: remove old skill entry (symlink or real directory with symlinked SKILL.md)
_cleanup_skill_entry() {
  local entry="$1"
  if [ -L "$entry" ]; then
    rm -f "$entry"
  elif [ -d "$entry" ] && [ -L "$entry/SKILL.md" ]; then
    rm -rf "$entry"
  fi
}

# Discover skills (directories with SKILL.md, excluding meta dirs)
SKILL_COUNT=0
for skill_dir in "$INSTALL_DIR"/*/; do
  [ -d "$skill_dir" ] || continue
  skill=$(basename "$skill_dir")
  # Skip non-skill directories
  case "$skill" in bin|browse|design|docs|extension|lib|node_modules|scripts|test|.git|.github) continue ;; esac
  [ -f "$skill_dir/SKILL.md" ] || continue

  if [ "$PREFIX" = "true" ]; then
    # Don't double-prefix directories already named rezops-*
    case "$skill" in
      rezops-*) link_name="$skill" ;;
      *)        link_name="rezops-$skill" ;;
    esac
    # Remove old flat entry if it exists (and isn't the same as the new link)
    [ "$link_name" != "$skill" ] && _cleanup_skill_entry "$SKILLS_DIR/$skill"
  else
    link_name="$skill"
    # Don't remove rezops-* dirs that are their real name (e.g., rezops-upgrade)
    case "$skill" in
      rezops-*) ;; # Already the real name, no old prefixed link to clean
      *)        _cleanup_skill_entry "$SKILLS_DIR/rezops-$skill" ;;
    esac
  fi
  target="$SKILLS_DIR/$link_name"
  # Upgrade old directory symlinks to real directories
  [ -L "$target" ] && rm -f "$target"
  # Create real directory with symlinked SKILL.md (absolute path)
  mkdir -p "$target"
  ln -snf "$INSTALL_DIR/$skill/SKILL.md" "$target/SKILL.md"
  SKILL_COUNT=$((SKILL_COUNT + 1))
done

# Patch SKILL.md name: fields to match prefix setting
"$INSTALL_DIR/bin/rezops-patch-names" "$INSTALL_DIR" "$PREFIX"

if [ "$PREFIX" = "true" ]; then
  echo "Relinked $SKILL_COUNT skills as rezops-*"
else
  echo "Relinked $SKILL_COUNT skills as flat names"
fi
