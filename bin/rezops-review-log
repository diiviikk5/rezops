#!/usr/bin/env bash
# rezops-review-log — atomically log a review result
# Usage: rezops-review-log '{"skill":"...","timestamp":"...","status":"..."}'
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval "$("$SCRIPT_DIR/rezops-slug" 2>/dev/null)"
REZOPS_HOME="${REZOPS_HOME:-$HOME/.rezops}"
mkdir -p "$REZOPS_HOME/projects/$SLUG"

# Validate: input must be parseable JSON (reject malformed or injection attempts)
INPUT="$1"
if ! printf '%s' "$INPUT" | bun -e "JSON.parse(await Bun.stdin.text())" 2>/dev/null; then
  # Not valid JSON — refuse to append
  echo "rezops-review-log: invalid JSON, skipping" >&2
  exit 1
fi

echo "$INPUT" >> "$REZOPS_HOME/projects/$SLUG/$BRANCH-reviews.jsonl"
